<style>
/* ── TOKENS ── */
:root {
  --bg:#06080A; --bg1:#0A0D10; --bg2:#0E1218; --bg3:#131820;
  --line:#171D24; --line2:#1E2830; --line3:#253040;
  --dim:#3A4D5A; --mid:#7080909; --mid:#708090; --ink:#D0D8D0; --ink2:#EDF0EA;
  --a:#C6450A; --ahi:#E05C1A; --adim:rgba(198,69,10,.10);
  --green:#28B862; --yellow:#C09818; --red:#DC4040; --cyan:#28A0C0;
  --mono:'JetBrains Mono',ui-monospace,monospace;
  --display:'Syne',sans-serif;
  --ease:cubic-bezier(.22,.68,0,1.2);
  --ease2:cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:var(--mono);font-size:14px;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:inherit;text-decoration:none}
::selection{background:var(--a);color:#06080A}
.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

/* Grain */
body::before{content:"";position:fixed;inset:0;pointer-events:none;z-index:998;opacity:.026;mix-blend-mode:overlay;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='3' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>")}

/* Custom cursor dot — blue brand color */
#cursor{position:fixed;width:6px;height:6px;border-radius:50%;background:var(--cyan);pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .2s,height .2s,opacity .2s;mix-blend-mode:normal}
#cursor-ring{position:fixed;width:32px;height:32px;border-radius:50%;border:1px solid rgba(40,160,192,.4);pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .35s var(--ease2),height .35s var(--ease2),border-color .35s,opacity .3s}
body:hover #cursor{opacity:1}
body.cursor-hover #cursor-ring{width:48px;height:48px;border-color:rgba(40,160,192,.75)}

/* Layout */
.wrap{max-width:1380px;margin:0 auto;padding:0 48px}
@media(max-width:768px){.wrap{padding:0 20px}}
@media(max-width:480px){.wrap{padding:0 16px}}

/* ── NAV ── */
.nav{position:fixed;top:0;left:0;right:0;z-index:500;height:58px;display:flex;align-items:center;transition:background .4s,border-color .4s}
.nav.scrolled{background:rgba(6,8,10,.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--line)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;width:100%}
.brand{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:13px;font-weight:500}
.brand-orb{width:8px;height:8px;border-radius:50%;background:var(--a);box-shadow:0 0 18px rgba(198,69,10,.85);animation:orb 2.4s ease-in-out infinite}
@keyframes orb{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.65);opacity:.35}}
.brand em{font-style:normal;color:var(--a)}
.nav-links{display:flex;gap:36px;font-size:11px;color:var(--mid);letter-spacing:.06em}
.nav-links a{position:relative;padding-bottom:3px;transition:color .15s}
.nav-links a::after{content:"";position:absolute;left:0;right:100%;bottom:0;height:1px;background:var(--a);transition:right .22s}
.nav-links a:hover{color:var(--ink2)}
.nav-links a:hover::after{right:0}
.nav-cta{font-size:11px;letter-spacing:.08em;padding:7px 16px;border:1px solid var(--line2);color:var(--ink);transition:all .18s}
.nav-cta:hover{border-color:var(--a);color:var(--a)}
/* Mobile nav */
.nav-burger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
.nav-burger span{display:block;width:20px;height:1px;background:var(--ink);transition:all .2s}
@media(max-width:800px){
  .nav-links,.nav-cta{display:none}
  .nav-burger{display:flex}
  .nav.open .nav-links{display:flex;flex-direction:column;position:fixed;top:58px;left:0;right:0;background:rgba(6,8,10,.98);border-bottom:1px solid var(--line);padding:28px 20px;gap:24px;font-size:16px}
}

/* ── SCROLL REVEAL ── */
.r{opacity:0;transform:translateY(28px);transition:opacity .9s var(--ease2),transform .9s var(--ease2)}
.r.in{opacity:1;transform:none}
.r.d1{transition-delay:.1s}.r.d2{transition-delay:.18s}.r.d3{transition-delay:.26s}.r.d4{transition-delay:.34s}.r.d5{transition-delay:.42s}
@media(prefers-reduced-motion:reduce){.r{opacity:1;transform:none;transition:none}}

/* ── HERO ── */
.hero{min-height:100svh;position:relative;overflow:hidden;display:grid;grid-template-rows:1fr auto;padding-top:58px}
#bg-canvas{position:absolute;inset:0;width:100%;height:100%;z-index:0}
.hero-content{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;padding:80px 0 60px}
@media(max-width:960px){.hero-content{grid-template-columns:1fr;gap:48px;padding:60px 0 40px}}

.hero-left{}
.hero-eyebrow{display:inline-flex;align-items:center;gap:12px;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--dim);margin-bottom:32px}
.eyebrow-tick{width:28px;height:1px;background:var(--a)}
.eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--a);animation:orb 2s infinite}
.eyebrow em{font-style:normal;color:var(--a)}

h1.hl{
  font-family:var(--display);font-weight:800;
  font-size:clamp(52px,8.5vw,118px);
  line-height:.91;letter-spacing:-.045em;
  color:var(--ink2);margin-bottom:36px;
}
.hl .stroke{
  display:block;color:transparent;
  -webkit-text-stroke:1.5px var(--a);
  position:relative;
}
.hl .filled{
  display:block;
  background:linear-gradient(108deg,var(--ink2) 0%,var(--mid) 100%);
  -webkit-background-clip:text;background-clip:text;color:transparent;
}
.hl .amber-fill{
  display:block;
  background:linear-gradient(108deg,var(--a) 0%,var(--ahi) 60%,var(--a) 100%);
  background-size:200% 100%;
  -webkit-background-clip:text;background-clip:text;color:transparent;
  animation:shine 5s linear infinite;
}
@keyframes shine{0%{background-position:200% 0}100%{background-position:-200% 0}}

.hero-sub{font-size:clamp(14px,1.5vw,16px);line-height:1.85;color:var(--mid);max-width:48ch;margin-bottom:44px}
.hero-sub strong{color:var(--ink);font-weight:500}
.hero-sub em{font-style:normal;color:var(--a)}

.hero-actions{display:flex;gap:14px;flex-wrap:wrap}

/* Buttons */
.btn-p{display:inline-flex;align-items:center;gap:10px;padding:15px 26px;background:var(--a);color:#06080A;font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;border:none;cursor:pointer;position:relative;overflow:hidden;transition:background .2s,transform .2s,box-shadow .2s;touch-action:manipulation}
.btn-p::after{content:"";position:absolute;inset:0;background:linear-gradient(110deg,transparent 35%,rgba(255,255,255,.28) 50%,transparent 65%);transform:translateX(-100%);transition:transform .5s}
.btn-p:hover{background:var(--ahi);transform:translateY(-2px);box-shadow:0 16px 40px -12px rgba(198,69,10,.55)}
.btn-p:hover::after{transform:translateX(100%)}
.btn-g{display:inline-flex;align-items:center;gap:10px;padding:15px 26px;border:1px solid var(--line2);color:var(--ink);font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;transition:border-color .18s,color .18s;touch-action:manipulation}
.btn-g:hover{border-color:var(--ink);color:var(--ink2)}
.arr{transition:transform .18s}
.btn-p:hover .arr,.btn-g:hover .arr{transform:translateX(4px)}

/* ── HERO RIGHT — TOPOLOGY DIAGRAM ── */
.topo-wrap{position:relative}
.topo-frame{
  border:1px solid var(--line2);
  background:linear-gradient(160deg,rgba(14,18,24,.96),rgba(6,8,10,.98));
  position:relative;overflow:hidden;
  box-shadow:0 0 0 1px rgba(198,69,10,.06),0 40px 80px -20px rgba(0,0,0,.8),inset 0 1px 0 rgba(255,255,255,.03);
}
/* Top scan line */
.topo-frame::before{content:"";position:absolute;left:0;right:0;top:0;height:1px;background:linear-gradient(90deg,transparent,var(--a),transparent);opacity:.5;z-index:3;pointer-events:none}
.topo-head{display:flex;align-items:stretch;border-bottom:1px solid var(--line);font-size:10px;color:var(--mid);position:relative;z-index:2}
.th-cell{padding:8px 14px;border-right:1px solid var(--line);display:flex;align-items:center;gap:7px}
.th-cell:last-child{border-right:none;margin-left:auto}
.th-lbl{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--dim)}
.th-val{color:var(--ink)}
.th-val.a{color:var(--a)}
.th-val.g{color:var(--green)}
.th-val.y{color:var(--yellow)}
.th-val.r{color:var(--red)}

/* The canvas inside topo */
#topo-canvas{display:block;width:100%;aspect-ratio:4/3}

/* Corner ticks */
.cx{position:absolute;width:12px;height:12px;border-color:rgba(198,69,10,.4);border-style:solid;pointer-events:none;z-index:4}
.cx.tl{top:-1px;left:-1px;border-width:1.5px 0 0 1.5px}
.cx.tr{top:-1px;right:-1px;border-width:1.5px 1.5px 0 0}
.cx.bl{bottom:-1px;left:-1px;border-width:0 0 1.5px 1.5px}
.cx.br{bottom:-1px;right:-1px;border-width:0 1.5px 1.5px 0}

.topo-foot{display:flex;justify-content:space-between;align-items:center;padding:8px 14px;border-top:1px solid var(--line);font-size:9px;color:var(--dim);letter-spacing:.1em;text-transform:uppercase}

/* Parallax layers in hero */
.hero-bg-glow{position:absolute;pointer-events:none;border-radius:50%;filter:blur(60px);z-index:1}
.glow-a{width:800px;height:800px;top:-200px;right:-200px;background:radial-gradient(circle,rgba(198,69,10,.08),transparent 70%);transition:transform .1s linear}
.glow-b{width:500px;height:500px;bottom:-100px;left:-100px;background:radial-gradient(circle,rgba(40,160,192,.05),transparent 70%)}

/* ── STAT STRIP ── */
.stats{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--bg1)}
.stat{padding:24px 32px;border-right:1px solid var(--line)}
.stat:last-child{border-right:none}
.stat-k{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--dim);margin-bottom:8px}
.stat-v{font-family:var(--display);font-size:clamp(26px,3vw,42px);font-weight:700;color:var(--ink2);letter-spacing:-.03em;line-height:1}
.stat-v .u{font-size:.45em;color:var(--dim);margin-left:3px;font-weight:400}
@media(max-width:768px){
  .stats{grid-template-columns:1fr 1fr}
  .stat{padding:18px 20px}
  .stat:nth-child(2){border-right:none}
  .stat:nth-child(3),.stat:nth-child(4){border-top:1px solid var(--line)}
  .stat:nth-child(4){border-right:none}
}
@media(max-width:480px){
  .stats{grid-template-columns:1fr}
  .stat{border-right:none;border-bottom:1px solid var(--line)}
  .stat:last-child{border-bottom:none}
}

/* ── SECTION BASE ── */
.sec{padding:120px 0;position:relative}
@media(max-width:768px){.sec{padding:72px 0}}
.sec-lbl{display:inline-flex;align-items:center;gap:14px;font-size:9px;letter-spacing:.24em;text-transform:uppercase;color:var(--a);margin-bottom:52px}
.sec-lbl::before{content:"";width:24px;height:1px;background:var(--a)}
.sec-h{font-family:var(--display);font-size:clamp(34px,5vw,68px);font-weight:700;letter-spacing:-.035em;line-height:1.01;color:var(--ink2);margin-bottom:20px}
.sec-p{font-size:15px;line-height:1.82;color:var(--mid);max-width:56ch}

/* ── HOW IT WORKS ── */
.how-bg{background:var(--bg1)}
.how-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
@media(max-width:900px){.how-grid{grid-template-columns:1fr;gap:40px}}

.steps{display:flex;flex-direction:column;margin-top:16px}
.step{
  border-bottom:1px solid var(--line);
  padding:28px 0 28px 0;
  display:grid;grid-template-columns:56px 1fr;gap:0 20px;
  cursor:pointer;position:relative;
  transition:background .2s;
}
.step:first-child{border-top:1px solid var(--line)}
.step.on{background:linear-gradient(90deg,rgba(198,69,10,.06),transparent 80%)}
/* Active left bar */
.step::before{content:"";position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--a);transform:scaleY(0);transform-origin:top;transition:transform .4s var(--ease2)}
.step.on::before{transform:scaleY(1)}

.step-n{font-family:var(--display);font-size:44px;font-weight:800;color:var(--line3);line-height:1;transition:color .3s;text-align:center;padding-top:2px}
.step.on .step-n{color:var(--a)}

.step-body h3{font-family:var(--display);font-size:19px;font-weight:600;letter-spacing:-.02em;color:var(--ink2);margin-bottom:0;transition:color .2s}
.step.on .step-body h3{color:var(--a)}
.step-body p{font-size:13px;color:var(--mid);line-height:1.78;max-height:0;overflow:hidden;opacity:0;transition:max-height .45s var(--ease2),opacity .3s,margin .3s}
.step.on .step-body p{max-height:180px;opacity:1;margin-top:10px}

/* How canvas */
.how-visual{position:sticky;top:80px}
#how-cv{display:block;width:100%;aspect-ratio:4/3;border:1px solid var(--line);background:var(--bg)}
.how-cv-note{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);text-align:center;margin-top:10px}

/* ── INPUTS ── */
.inp-sec{background:var(--bg)}
.inp-head{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:end;margin-bottom:56px}
@media(max-width:768px){.inp-head{grid-template-columns:1fr}}

.inp-grid{display:grid;grid-template-columns:repeat(12,1fr);border:1px solid var(--line)}
.ic{padding:30px 28px;border-right:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--bg1);position:relative;overflow:hidden;transition:background .22s}
.ic:hover{background:var(--bg2)}
.ic.w6{grid-column:span 6}.ic.w4{grid-column:span 4}.ic.w12{grid-column:span 12;border-bottom:none}.ic.nr{border-right:none}
.ic::before{content:"";position:absolute;inset:0;pointer-events:none;opacity:0;transition:opacity .28s;background:radial-gradient(420px 300px at var(--mx,50%) var(--my,50%),rgba(198,69,10,.07),transparent 68%)}
.ic:hover::before{opacity:1}
/* Corner clip */
.ic::after{content:"";position:absolute;top:0;right:0;border-left:1px solid var(--line2);border-bottom:1px solid var(--line2);width:40px;height:40px;clip-path:polygon(100% 0,100% 100%,0 100%);opacity:.5}

.ic-tag{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--a);margin-bottom:14px;display:flex;align-items:center;gap:7px}
.ic-tag::before{content:"//";color:var(--dim)}
.ic h3{font-family:var(--display);font-size:21px;font-weight:600;letter-spacing:-.025em;color:var(--ink2);margin-bottom:10px;transition:color .2s}
.ic:hover h3{color:var(--a)}
.ic p{font-size:13px;color:var(--mid);line-height:1.7;max-width:42ch}
.ic-pills{display:flex;flex-wrap:wrap;gap:7px;margin-top:18px}
.pill{font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--dim);padding:4px 8px;border:1px solid var(--line2)}
.ic-bg-svg{position:absolute;bottom:0;right:0;width:44%;height:62%;opacity:.1;pointer-events:none}

@media(max-width:900px){
  .inp-grid{grid-template-columns:1fr}
  .ic{grid-column:span 12!important;border-right:none!important}
}

/* ── OUTPUTS ── */
.out-sec{background:var(--bg1)}
.out-cols{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid var(--line);margin-top:56px}
.oc{padding:44px 36px;border-right:1px solid var(--line);background:var(--bg2);position:relative;overflow:hidden;transition:background .25s}
.oc:last-child{border-right:none}
.oc:hover{background:var(--bg3)}
/* Bottom sweep on hover */
.oc::after{content:"";position:absolute;left:0;right:0;bottom:0;height:2px;background:var(--a);transform:scaleX(0);transform-origin:left;transition:transform .4s var(--ease2)}
.oc:hover::after{transform:scaleX(1)}
/* Big number watermark */
.oc-n{font-family:var(--display);font-size:80px;font-weight:800;color:var(--line);line-height:1;margin-bottom:20px;transition:color .3s}
.oc:hover .oc-n{color:var(--line2)}
.oc h3{font-family:var(--display);font-size:20px;font-weight:600;letter-spacing:-.02em;color:var(--ink2);margin-bottom:12px}
.oc p{font-size:13px;color:var(--mid);line-height:1.78}
.oc p strong{color:var(--ink);font-weight:500}
@media(max-width:900px){
  .out-cols{grid-template-columns:1fr}
  .oc{border-right:none;border-bottom:1px solid var(--line)}
  .oc:last-child{border-bottom:none}
}

/* NOTE */
.note{margin-top:36px;padding:22px 28px;border-left:2px solid var(--a);background:var(--bg2);font-size:14px;color:var(--mid);line-height:1.78;max-width:80ch}
.note strong{color:var(--ink);font-weight:500}

/* ── CALLOUT BAND ── */
.callout{background:var(--a);padding:72px 0;position:relative;overflow:hidden}
.callout::before{content:"";position:absolute;inset:0;background:repeating-linear-gradient(45deg,transparent,transparent 36px,rgba(0,0,0,.04) 36px,rgba(0,0,0,.04) 37px)}
.callout-inner{display:flex;align-items:center;justify-content:space-between;gap:48px;flex-wrap:wrap;position:relative;z-index:1}
.callout h2{font-family:var(--display);font-size:clamp(28px,4.5vw,58px);font-weight:800;letter-spacing:-.04em;color:#06080A;line-height:1;margin-bottom:10px}
.callout p{font-size:15px;color:rgba(6,8,10,.6);line-height:1.6}
.btn-dark{display:inline-flex;align-items:center;gap:10px;padding:16px 28px;background:#06080A;color:var(--a);font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap;transition:background .18s,color .18s;touch-action:manipulation}
.btn-dark:hover{background:var(--ink2);color:#06080A}

/* ── CONTACT ── */
.contact-sec{background:var(--bg);padding-bottom:100px}
.contact-wrap{display:grid;grid-template-columns:300px 1fr;gap:48px;border:1px solid var(--line);padding:48px;position:relative;background:linear-gradient(140deg,var(--bg1),var(--bg));overflow:hidden}
@media(max-width:1100px){.contact-wrap{grid-template-columns:1fr;padding:36px 24px;gap:36px}}
.contact-intro h2{font-family:var(--display);font-size:clamp(26px,3.2vw,44px);font-weight:700;letter-spacing:-.035em;color:var(--ink2);margin-bottom:18px;line-height:1.08}
.contact-intro p{font-size:14px;color:var(--mid);line-height:1.78;margin-bottom:24px}
.contact-sub{font-size:12px;color:var(--dim);border-top:1px dashed var(--line2);padding-top:18px;margin-top:20px}
.contact-sub a{color:var(--a);transition:color .15s}
.contact-sub a:hover{color:var(--ahi)}

.cform{display:grid;grid-template-columns:1fr 1fr;gap:26px 32px}
@media(max-width:600px){.cform{grid-template-columns:1fr}}
.f{display:flex;flex-direction:column;gap:7px}
.f.full{grid-column:1/-1}
