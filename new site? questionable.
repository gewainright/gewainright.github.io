<script>
'use strict';
/* ── UTILITIES ── */
const $ = s => document.querySelector(s);
const $$ = s => [...document.querySelectorAll(s)];
const lerp = (a, b, t) => a + (b - a) * t;
const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));

/* ── YEAR ── */
$('#fy').textContent = new Date().getFullYear();

/* ── CUSTOM CURSOR ── */
const cur = $('#cursor'), ring = $('#cursor-ring');
let mx = -100, my = -100, rx = -100, ry = -100;
document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
(function tickCursor() {
  rx = lerp(rx, mx, .12); ry = lerp(ry, my, .12);
  cur.style.left = mx + 'px'; cur.style.top = my + 'px';
  ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
  requestAnimationFrame(tickCursor);
})();
$$('a,button,.step,.ic,.oc').forEach(el => {
  el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
  el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
});

/* ── NAV ── */
const nav = $('#nav');
window.addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 50), { passive: true });
$('#burger').addEventListener('click', function() {
  const open = nav.classList.toggle('open');
  this.setAttribute('aria-expanded', open);
});

/* ── SCROLL REVEAL ── */
const ro = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); ro.unobserve(e.target); } });
}, { threshold: .1, rootMargin: '0px 0px -36px 0px' });
$$('.r').forEach(el => ro.observe(el));

/* ── MOUSE PARALLAX on HERO GLOW ── */
const glowA = $('#glow-a');
document.addEventListener('mousemove', e => {
  const xPct = e.clientX / window.innerWidth - .5;
  const yPct = e.clientY / window.innerHeight - .5;
  if (glowA) glowA.style.transform = `translate(${xPct * -40}px, ${yPct * -30}px)`;
}, { passive: true });

/* ── BG CANVAS — particle network ── */
(function () {
  const cv = $('#bg-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H, pts, raf;
  const N = window.innerWidth < 768 ? 35 : 65;
  const DIST = 130;
  const AM = [198, 69, 10];

  function resize() { W = cv.width = cv.offsetWidth; H = cv.height = cv.offsetHeight; }

  function mkPt() {
    return { x: Math.random()*W, y: Math.random()*H, vx: (Math.random()-.5)*.25, vy: (Math.random()-.5)*.25, r: Math.random()*1.2+.4, o: Math.random()*.4+.15 };
  }

  function draw() {
    ctx.clearRect(0,0,W,H);
    for (let i=0;i<pts.length;i++) {
      pts[i].x+=pts[i].vx; pts[i].y+=pts[i].vy;
      if(pts[i].x<0)pts[i].x=W; if(pts[i].x>W)pts[i].x=0;
      if(pts[i].y<0)pts[i].y=H; if(pts[i].y>H)pts[i].y=0;
      for(let j=i+1;j<pts.length;j++){
        const dx=pts[i].x-pts[j].x, dy=pts[i].y-pts[j].y, d=Math.hypot(dx,dy);
        if(d<DIST){ ctx.strokeStyle=`rgba(${AM},${(1-d/DIST)*.1})`; ctx.lineWidth=.5; ctx.beginPath(); ctx.moveTo(pts[i].x,pts[i].y); ctx.lineTo(pts[j].x,pts[j].y); ctx.stroke(); }
      }
      ctx.beginPath(); ctx.arc(pts[i].x,pts[i].y,pts[i].r,0,6.28); ctx.fillStyle=`rgba(${AM},${pts[i].o})`; ctx.fill();
    }
    raf = requestAnimationFrame(draw);
  }
  document.addEventListener('visibilitychange', () => { if(document.hidden)cancelAnimationFrame(raf); else raf=requestAnimationFrame(draw); });
  window.addEventListener('resize', resize, {passive:true});
  resize(); pts = Array.from({length:N}, mkPt); raf=requestAnimationFrame(draw);
})();

/* ── TOPOLOGY CANVAS (hero right) ── */
(function () {
  const cv = $('#topo-canvas');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H, raf, t = 0;

  const SENSORS = [
    {label:'USN', name:'Ultrasound',   color:'#C6450A'},
    {label:'ACC', name:'Accelerometer',color:'#C6450A'},
    {label:'TMP', name:'Temperature',  color:'#28A0C0'},
    {label:'PSI', name:'Pressure',     color:'#28A0C0'},
    {label:'AMP', name:'Current',      color:'#C09818'},
  ];
  const STATES = [
    {label:'Nominal',   cls:'g', dot:'#28B862', dur:280},
    {label:'Degrading', cls:'y', dot:'#C09818', dur:180},
    {label:'Nominal',   cls:'g', dot:'#28B862', dur:220},
    {label:'Fault',     cls:'r', dot:'#DC4040', dur:100},
  ];
  let stIdx=0, stTimer=0;
  const flows = SENSORS.map(()=>({t:Math.random()}));

  function resize() {
    const r = cv.parentElement.getBoundingClientRect();
    const dpr = Math.min(window.devicePixelRatio||1, 2);
    const w = r.width; const h = w * .75;
    cv.width = w*dpr; cv.height = h*dpr;
    cv.style.width = w+'px'; cv.style.height = h+'px';
    ctx.setTransform(dpr,0,0,dpr,0,0);
    W=w; H=h;
  }

  function bez(p0,p1,p2,p3,t){ const m=1-t; return m*m*m*p0+3*m*m*t*p1+3*m*t*t*p2+t*t*t*p3; }

  function tick() {
    t++; stTimer++;
    const st = STATES[stIdx];
    if (stTimer > st.dur) { stTimer=0; stIdx=(stIdx+1)%STATES.length; }
    ctx.clearRect(0,0,W,H);

    const pad=W*.05, sw=W*.2, sh=H*.1, sx=pad;
    const ux=W*.38, uy=H*.12, uw=W*.24, uh=H*.76;
    const ox=W*.72, ow=W*.23, oh=uh*.7, oy=uy+uh*.15;

    // Grid
    ctx.strokeStyle='rgba(23,29,36,.9)'; ctx.lineWidth=1;
    for(let x=0;x<W;x+=W/14){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
    for(let y=0;y<H;y+=H/10){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

    SENSORS.forEach((s,i)=>{
      const sy = pad + i*(H-pad*2)/SENSORS.length + (H-pad*2)/SENSORS.length/2 - sh/2;
      const cy = sy + sh/2;
      const ucy = uy + (i+.5)*uh/SENSORS.length;

      // Sensor box
      ctx.fillStyle='rgba(10,13,16,.95)'; ctx.strokeStyle='rgba(30,40,48,1)'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.rect(sx,sy,sw,sh); ctx.fill(); ctx.stroke();
      // Label chip
      ctx.fillStyle=s.color+'33'; ctx.fillRect(sx+2,sy+2,sw*.28,sh-4);
      ctx.fillStyle=s.color; ctx.font=`700 ${W*.022}px 'JetBrains Mono'`; ctx.textAlign='center';
      ctx.fillText(s.label, sx+sw*.14, sy+sh*.65);
      ctx.fillStyle='#708090'; ctx.font=`${W*.018}px 'JetBrains Mono'`; ctx.textAlign='left';
      ctx.fillText(s.name, sx+sw*.33, sy+sh*.65);

      // Bezier line to unit
      const lx0=sx+sw, lx1=ux;
      ctx.setLineDash([3,5]); ctx.strokeStyle='rgba(30,40,48,1)'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(lx0,cy);
      ctx.bezierCurveTo(lx0+(lx1-lx0)*.45,cy, lx1-(lx1-lx0)*.45,ucy, lx1,ucy);
      ctx.stroke(); ctx.setLineDash([]);

      // Flow dot
      flows[i].t += .005; if(flows[i].t>1)flows[i].t=0;
      const ft=flows[i].t;
      const fx=bez(lx0,lx0+(lx1-lx0)*.45,lx1-(lx1-lx0)*.45,lx1,ft);
      const fy=bez(cy,cy,ucy,ucy,ft);
      const fa=ft<.1?ft*10:ft>.9?(1-ft)*10:1;
      ctx.beginPath(); ctx.arc(fx,fy,W*.014,0,6.28); ctx.fillStyle=`rgba(${hexRgb(s.color)},${fa*.8})`; ctx.fill();
      ctx.beginPath(); ctx.arc(fx,fy,W*.007,0,6.28); ctx.fillStyle=`rgba(255,255,255,${fa*.4})`; ctx.fill();
    });

    // OSREP unit
    const pulse = .35+Math.sin(t*.05)*.12;
    ctx.shadowColor='rgba(198,69,10,.5)'; ctx.shadowBlur=20;
    ctx.strokeStyle=`rgba(198,69,10,${pulse})`; ctx.lineWidth=1.5;
    ctx.fillStyle='rgba(10,13,16,.97)';
    ctx.beginPath(); ctx.rect(ux,uy,uw,uh); ctx.fill(); ctx.stroke();
    ctx.shadowBlur=0;
    // Inner gradient
    const g=ctx.createLinearGradient(ux,uy,ux,uy+uh);
    g.addColorStop(0,'rgba(198,69,10,.09)'); g.addColorStop(1,'rgba(198,69,10,.01)');
    ctx.fillStyle=g; ctx.fillRect(ux+1,uy+1,uw-2,uh-2);
    // Text
    ctx.fillStyle='#C6450A'; ctx.font=`500 ${W*.018}px 'JetBrains Mono'`; ctx.textAlign='center';
    ctx.fillText('edge unit', ux+uw/2, uy+uh*.18);
    ctx.fillStyle='#EDF0EA'; ctx.font=`700 ${W*.052}px 'Syne'`;
    ctx.fillText('OSREP', ux+uw/2, uy+uh*.42);
    ctx.fillStyle='#3A4D5A'; ctx.font=`${W*.016}px 'JetBrains Mono'`;
    ctx.fillText('on-unit inference', ux+uw/2, uy+uh*.58);
    ctx.fillText('no cloud', ux+uw/2, uy+uh*.68);
    // Blink dot
    const bd=Math.sin(t*.1)>.2?1:.25;
    ctx.beginPath(); ctx.arc(ux+uw/2,uy+uh*.82,W*.012,0,6.28);
    ctx.fillStyle=`rgba(40,184,98,${bd})`; ctx.shadowColor='rgba(40,184,98,.8)'; ctx.shadowBlur=8*bd; ctx.fill(); ctx.shadowBlur=0;

    // Arrow
    const ax=ux+uw, ax2=ox;
    ctx.strokeStyle='rgba(198,69,10,.65)'; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.moveTo(ax,uy+uh/2); ctx.lineTo(ax2-8,uy+uh/2); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(ax2-12,uy+uh/2-6); ctx.lineTo(ax2,uy+uh/2); ctx.lineTo(ax2-12,uy+uh/2+6);
    ctx.strokeStyle='rgba(198,69,10,.9)'; ctx.stroke();

    // State panel
    const cst=STATES[stIdx];
    ctx.fillStyle='rgba(10,13,16,.96)'; ctx.strokeStyle='rgba(30,40,48,1)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.rect(ox,oy,ow,oh); ctx.fill(); ctx.stroke();
    ctx.fillStyle='#3A4D5A'; ctx.font=`${W*.015}px 'JetBrains Mono'`; ctx.textAlign='center';
    ctx.fillText('// current state', ox+ow/2, oy+oh*.16);
    // Dot
    const dc=oy+oh*.38, dd=W*.024;
    ctx.beginPath(); ctx.arc(ox+ow/2,dc,dd,0,6.28);
    ctx.fillStyle=cst.dot; ctx.shadowColor=cst.dot; ctx.shadowBlur=14; ctx.fill(); ctx.shadowBlur=0;
    ctx.fillStyle=cst.dot; ctx.font=`700 ${W*.034}px 'Syne'`;
    ctx.fillText(cst.label, ox+ow/2, oy+oh*.62);
    ctx.fillStyle='#3A4D5A'; ctx.font=`${W*.013}px 'JetBrains Mono'`;
    const since = stIdx===0?'stable · 14d':stIdx===1?'acoustic ↑40% · 3h':stIdx===2?'resolved · 4m':'fault · 2m';
    ctx.fillText(since, ox+ow/2, oy+oh*.76);
    // Update header
    const hdr=$('#hdr-state');
    if(hdr){ hdr.textContent=cst.label.toLowerCase(); hdr.className='th-val '+cst.cls; }

    raf=requestAnimationFrame(tick);
  }

  function hexRgb(h){return `${parseInt(h.slice(1,3),16)},${parseInt(h.slice(3,5),16)},${parseInt(h.slice(5,7),16)}`;}

  document.addEventListener('visibilitychange',()=>{if(document.hidden)cancelAnimationFrame(raf);else raf=requestAnimationFrame(tick);});
  window.addEventListener('resize',()=>{resize();},{passive:true});
  resize(); raf=requestAnimationFrame(tick);
})();

/* ── HOW CANVAS (step visualizer) ── */
(function () {
  const cv = $('#how-cv');
  if (!cv) return;
  const ctx = cv.getContext('2d');
  let W, H, raf, t=0, activeStep=0, lastInteraction=0, autoTimer=null;

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = cv.getBoundingClientRect();
    W = rect.width > 2 ? rect.width : (cv.offsetWidth || 400);
    H = W * .75;
    cv.width = Math.round(W * dpr);
    cv.height = Math.round(H * dpr);
    cv.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function init() {
    resize();
    if (W < 4) { requestAnimationFrame(init); return; }
    raf = requestAnimationFrame(tick);
    startAuto();
  }

  const scenes = [
    // Scene 0: Mount — sensors left, unit right, bezier wires, no overlap
    function(t) {
      ctx.clearRect(0,0,W,H);
      drawGrid();

      const LABELS = ['USN','ACC','TMP','PSI','AMP'];
      const NAMES  = ['Ultrasound','Accelerometer','Temperature','Pressure','Current'];
      const COLORS = ['#C6450A','#C6450A','#28A0C0','#28A0C0','#C09818'];

      const sBoxW = W * .24;
      const sBoxH = H * .11;
      const sBoxX = W * .03;
      const vPad  = H * .07;
      const usable = H - vPad * 2;
      const slot   = usable / LABELS.length;

      const uX = W * .65;
      const uW = W * .30;
      const uH = H * .80;
      const uY = (H - uH) / 2;

      LABELS.forEach((lbl, i) => {
        const progress = clamp((t - i * 18) / 55, 0, 1);
        if (progress <= 0) return;

        const sCY = vPad + slot * i + slot / 2;
        const sRX = sBoxX + sBoxW;
        const wireY = uY + uH * ((i + .5) / LABELS.length);
        const cp1x = sRX + (uX - sRX) * .45;
        const cp2x = uX - (uX - sRX) * .45;

        // Wire
        ctx.setLineDash([3, 5]);
        ctx.strokeStyle = 'rgba(' + hexRgb(COLORS[i]) + ',' + (progress * .4) + ')';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(sRX, sCY);
        ctx.bezierCurveTo(cp1x, sCY, cp2x, wireY, uX, wireY);
        ctx.stroke();
        ctx.setLineDash([]);

        // Flow dot
        const ft = ((t * .006 + i * .22) % 1);
        const fa = ft < .1 ? ft * 10 : ft > .88 ? (1 - ft) * 8 : 1;
        const fdx = bez4(sRX, cp1x, cp2x, uX, ft);
        const fdy = bez4(sCY, sCY, wireY, wireY, ft);
        ctx.beginPath();
        ctx.arc(fdx, fdy, W * .012, 0, 6.28);
        ctx.fillStyle = 'rgba(' + hexRgb(COLORS[i]) + ',' + (fa * progress * .8) + ')';
        ctx.fill();

        // Sensor box
        const bx = sBoxX, by = sCY - sBoxH / 2;
        ctx.fillStyle = 'rgba(10,13,16,' + progress + ')';
        ctx.strokeStyle = 'rgba(30,40,48,' + progress + ')';
        ctx.lineWidth = 1;
        ctx.fillRect(bx, by, sBoxW, sBoxH);
        ctx.strokeRect(bx, by, sBoxW, sBoxH);

        // Color chip
        ctx.fillStyle = 'rgba(' + hexRgb(COLORS[i]) + ',.14)';
        ctx.fillRect(bx + 1, by + 1, sBoxW * .26, sBoxH - 2);

        // Label + name
        ctx.fillStyle = 'rgba(' + hexRgb(COLORS[i]) + ',' + progress + ')';
        ctx.font = '700 ' + (W * .019) + 'px JetBrains Mono';
        ctx.textAlign = 'center';
        ctx.fillText(lbl, bx + sBoxW * .13, sCY + W * .007);
        ctx.fillStyle = 'rgba(112,128,144,' + progress + ')';
        ctx.font = (W * .015) + 'px JetBrains Mono';
        ctx.textAlign = 'left';
        ctx.fillText(NAMES[i], bx + sBoxW * .3, sCY + W * .006);
      });

      // Unit
      const up = clamp((t - 32) / 45, 0, 1);
      drawUnit(uX, uY, uW, uH, up, t);

      function bez4(p0,p1,p2,p3,t){const m=1-t;return m*m*m*p0+3*m*m*t*p1+3*m*t*t*p2+t*t*t*p3;}
    },
    // Scene 1: Learn — shows waveform + model forming
    function(t) {
      ctx.clearRect(0,0,W,H);
      drawGrid();
      // Waveform building
      ctx.strokeStyle='rgba(198,69,10,.7)'; ctx.lineWidth=1.5;
      ctx.beginPath();
      const pts=Math.floor(clamp(t/2,0,W));
      for(let i=0;i<pts;i++){
        const x=(i/W)*W;
        const y=H*.5+Math.sin(i*.18)*H*.15+Math.sin(i*.41)*.08*H+Math.sin(i*.9)*.05*H+(Math.random()-.5)*4;
        i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      }
      ctx.stroke();
      // Model confidence bar
      const conf=clamp(t/120,0,1);
      ctx.fillStyle='rgba(14,18,24,.9)'; ctx.fillRect(W*.1,H*.72,W*.8,H*.08);
      ctx.fillStyle='rgba(198,69,10,.8)'; ctx.fillRect(W*.1,H*.72,W*.8*conf,H*.08);
      ctx.strokeStyle='rgba(30,40,48,1)'; ctx.lineWidth=1; ctx.strokeRect(W*.1,H*.72,W*.8,H*.08);
      ctx.fillStyle='#708090'; ctx.font=`${W*.016}px 'JetBrains Mono'`; ctx.textAlign='left';
      ctx.fillText('model confidence', W*.1, H*.68);
      ctx.textAlign='right'; ctx.fillStyle='#C6450A';
      ctx.fillText(Math.round(conf*100)+'%', W*.9, H*.68);
      // Label
      ctx.fillStyle='rgba(198,69,10,.6)'; ctx.font=`${W*.018}px 'JetBrains Mono'`; ctx.textAlign='center';
      ctx.fillText('learning baseline on-unit', W*.5, H*.2);
      ctx.fillStyle='#3A4D5A'; ctx.font=`${W*.014}px 'JetBrains Mono'`;
      ctx.fillText('no data transmitted', W*.5, H*.28);
    },
    // Scene 2: Emit — shows state output cycling
    function(t) {
      ctx.clearRect(0,0,W,H);
      drawGrid();
      // Timeline of states
      const states2=[
        {label:'Nominal',  color:'#28B862', len:.5},
        {label:'Degrading',color:'#C09818', len:.2},
        {label:'Nominal',  color:'#28B862', len:.3},
      ];
      let xOff=W*.05;
      states2.forEach(s=>{
        const sw=(W*.9)*s.len;
        const prog=clamp((t-30)/80,0,1);
        ctx.fillStyle=s.color+'18'; ctx.fillRect(xOff,H*.3,sw*prog,H*.35);
        ctx.strokeStyle=s.color+'60'; ctx.lineWidth=1; ctx.strokeRect(xOff,H*.3,sw,H*.35);
        ctx.fillStyle=s.color; ctx.font=`700 ${W*.026}px 'Syne'`; ctx.textAlign='center';
        if(prog>.3)ctx.fillText(s.label, xOff+sw/2, H*.51);
        xOff+=sw;
      });
      // Arrow + state box
      const p2=clamp((t-60)/40,0,1);
      if(p2>0){
        ctx.strokeStyle=`rgba(198,69,10,${p2*.7})`; ctx.lineWidth=1.5;
        ctx.beginPath(); ctx.moveTo(W*.5,H*.72); ctx.lineTo(W*.5,H*.82); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(W*.44,H*.79); ctx.lineTo(W*.5,H*.86); ctx.lineTo(W*.56,H*.79); ctx.stroke();
        ctx.fillStyle=`rgba(14,18,24,${p2})`; ctx.strokeStyle=`rgba(198,69,10,${p2*.5})`;
        ctx.fillRect(W*.3,H*.86,W*.4,H*.1); ctx.strokeRect(W*.3,H*.86,W*.4,H*.1);
        ctx.fillStyle=`rgba(40,184,98,${p2})`; ctx.font=`700 ${W*.022}px 'JetBrains Mono'`; ctx.textAlign='center';
        ctx.fillText('→ upstream', W*.5, H*.93);
      }
      ctx.fillStyle='#3A4D5A'; ctx.font=`${W*.014}px 'JetBrains Mono'`; ctx.textAlign='center';
      ctx.fillText('state timeline · asset 04', W*.5, H*.22);
    }
  ];

  function drawGrid(){
    ctx.strokeStyle='rgba(23,29,36,.8)'; ctx.lineWidth=1;
    for(let x=0;x<W;x+=W/14){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
    for(let y=0;y<H;y+=H/10){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
  }

  function drawUnit(x,y,w,h,alpha,t){
    const pulse=.3+Math.sin(t*.05)*.1;
    ctx.shadowColor='rgba(198,69,10,.5)'; ctx.shadowBlur=16*alpha;
    ctx.strokeStyle=`rgba(198,69,10,${pulse*alpha})`; ctx.lineWidth=1.5;
    ctx.fillStyle=`rgba(10,13,16,${alpha*.98})`;
    ctx.beginPath(); ctx.rect(x,y,w,h); ctx.fill(); ctx.stroke(); ctx.shadowBlur=0;
    if(alpha>.5){
      ctx.fillStyle=`rgba(198,69,10,${alpha})`; ctx.font=`600 ${W*.016}px 'JetBrains Mono'`; ctx.textAlign='center';
      ctx.fillText('OSREP', x+w/2, y+h*.45);
      ctx.fillStyle=`rgba(56,77,90,${alpha})`; ctx.font=`${W*.013}px 'JetBrains Mono'`;
      ctx.fillText('on-unit', x+w/2, y+h*.6);
    }
  }

  let sceneT=0;
  function tick(){
    t++; sceneT++;
    scenes[activeStep](sceneT);
    raf=requestAnimationFrame(tick);
  }

  // STEP INTERACTION — hover activates, not just click
  let idleTimer=null;
  function setStep(i){
    if(activeStep===i)return;
    activeStep=i; sceneT=0;
    $$('.step').forEach((s,j)=>{ s.classList.toggle('on',j===i); s.setAttribute('aria-expanded',j===i); });
    clearTimeout(idleTimer);
    lastInteraction=Date.now();
    // Resume auto after 8s idle
    idleTimer=setTimeout(startAuto, 8000);
  }

  function startAuto(){
    clearInterval(autoTimer);
    autoTimer=setInterval(()=>{
      if(Date.now()-lastInteraction>6000) setStep((activeStep+1)%3);
    }, 4000);
  }

  $$('.step').forEach((step,i)=>{
    // Hover activates
    step.addEventListener('mouseenter',()=>{ lastInteraction=Date.now(); setStep(i); });
    // Click also works
    step.addEventListener('click',()=>{ lastInteraction=Date.now(); setStep(i); });
    step.addEventListener('keydown',e=>{ if(e.key==='Enter'||e.key===' '){e.preventDefault();setStep(i);} });
  });

  document.addEventListener('visibilitychange',()=>{ if(document.hidden)cancelAnimationFrame(raf); else raf=requestAnimationFrame(tick); });
  window.addEventListener('resize',()=>{ resize(); },{passive:true});
  if (window.ResizeObserver) { new ResizeObserver(()=>{ resize(); }).observe(cv); }
  // Defer init until canvas has layout
  if (document.readyState === 'complete') { setTimeout(init, 50); }
  else { window.addEventListener('load', ()=>setTimeout(init, 50)); }
})();

/* ── INPUT CARD GLOW ── */
$$('.ic').forEach(c=>{
  c.addEventListener('mousemove',e=>{
    const r=c.getBoundingClientRect();
    c.style.setProperty('--mx',((e.clientX-r.left)/r.width*100)+'%');
    c.style.setProperty('--my',((e.clientY-r.top)/r.height*100)+'%');
  });
});

/* ── FORM ── */
(function(){
  const form=$('#cform'), ok=$('#form-ok'), btn=form.querySelector('.sub-btn');
  form.addEventListener('submit',async e=>{
    e.preventDefault();
    const hp=form.querySelector('[name="_gotcha"]'); if(hp&&hp.value)return;
    const fields=[['fn',form.name.value.trim()],['fe',form.email.value.trim()],['fi',form.industry.value],['fw',form.what.value.trim()]];
    let err=false;
    fields.forEach(([id,v])=>{
      const el=document.getElementById(id);
      if(!v){el.style.borderColor='var(--red)';el.style.borderBottomColor='var(--red)';el.setAttribute('aria-invalid','true');err=true;}
      else{el.style.borderColor='';el.style.borderBottomColor='';el.removeAttribute('aria-invalid');}
    });
    if(err)return;
    btn.disabled=true; const orig=btn.innerHTML; btn.innerHTML='Sending…';
    try{
      const res=await fetch(form.action,{method:'POST',headers:{Accept:'application/json'},body:new FormData(form)});
      if(res.ok){ok.classList.add('show');btn.innerHTML='✓ Sent';form.querySelectorAll('input,select,textarea').forEach(el=>el.disabled=true);}
      else{const d=await res.json().catch(()=>({}));btn.disabled=false;btn.innerHTML=orig;ok.innerHTML=`<strong style="color:var(--red)">✕ Something went wrong.</strong> Try again.${d.error?` (${d.error})`:''}`;ok.style.borderColor='var(--red)';ok.classList.add('show');}
    }catch{btn.disabled=false;btn.innerHTML=orig;ok.innerHTML='<strong style="color:var(--red)">✕ Network error.</strong>';ok.style.borderColor='var(--red)';ok.classList.add('show');}
  });
})();
