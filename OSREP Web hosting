<script>
  // Form
  const form = document.getElementById('contact-form');
  const successEl = document.getElementById('form-success');
  const submitBtn = form.querySelector('.submit');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = form.name.value.trim();
    const email = form.email.value.trim();
    const industry = form.industry.value;
    const what = form.what.value.trim();
    if (!name || !email || !industry || !what) {
      [['f-name',name],['f-email',email],['f-industry',industry],['f-what',what]].forEach(([id,v])=>{
        const el = document.getElementById(id);
        el.style.borderColor = v ? '' : 'var(--red)';
        el.style.borderBottomColor = v ? '' : 'var(--red)';
      });
      return;
    }
    submitBtn.disabled = true;
    const originalLabel = submitBtn.innerHTML;
    submitBtn.innerHTML = 'Sending\u2026';
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(form)
      });
      if (res.ok) {
        successEl.classList.add('show');
        submitBtn.innerHTML = '\u2713 Sent';
        form.querySelectorAll('input, select, textarea').forEach(el => el.disabled = true);
      } else {
        const data = await res.json().catch(()=>({}));
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalLabel;
        successEl.innerHTML = '<strong style="color:var(--red)">\u2715 Something went wrong.</strong> Please try again in a moment.' + (data.error ? ' <span style="color:var(--dim)">('+data.error+')</span>' : '');
        successEl.style.borderColor = 'var(--red)';
        successEl.classList.add('show');
      }
    } catch (err) {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalLabel;
      successEl.innerHTML = '<strong style="color:var(--red)">\u2715 Network error.</strong> Please check your connection and try again.';
      successEl.style.borderColor = 'var(--red)';
      successEl.classList.add('show');
    }
  });

  // ----- LIVE WAVEFORM -----
  const cvs = document.getElementById('wave');
  const ctx = cvs.getContext('2d');
  function sizeCanvas(){
    const r = cvs.getBoundingClientRect();
    if (r.width < 2 || r.height < 2) return; // defer if not yet laid out
    const dpr = window.devicePixelRatio || 1;
    cvs.width = Math.round(r.width * dpr);
    cvs.height = Math.round(r.height * dpr);
    ctx.setTransform(dpr,0,0,dpr,0,0);
  }
  sizeCanvas();
  window.addEventListener('resize', sizeCanvas);
  window.addEventListener('orientationchange', () => setTimeout(sizeCanvas, 150));
  // Re-measure when element resizes (handles mobile layout settling)
  if (window.ResizeObserver) {
    new ResizeObserver(sizeCanvas).observe(cvs.parentElement);
  }
  // Retry a few times after load in case fonts/layout shift
  [100, 400, 1000].forEach(ms => setTimeout(sizeCanvas, ms));

  const N = 320;
  let buf = new Array(N).fill(0);
  let t = 0;
  let anomalyUntil = 0;

  const anomalyEl = document.getElementById('anomaly');

  function rand(){ return Math.random()*2-1; }

  function step(){
    t += 1;
    // base signal: superposition of a couple harmonics + noise
    const base = 0.28*Math.sin(t*0.18) + 0.14*Math.sin(t*0.41 + 0.7) + 0.08*Math.sin(t*0.9);
    const noise = (rand()+rand()+rand())/3 * 0.18;
    let v = base + noise;

    // occasional anomaly burst
    if (Math.random() < 0.0015 && t > 180) {
      anomalyUntil = t + 70;
    }
    const inAnomaly = t < anomalyUntil;
    if (inAnomaly){
      v += Math.sin(t*2.3) * 0.55 + rand()*0.25;
    }

    buf.push(v); if (buf.length > N) buf.shift();

    anomalyEl.classList.toggle('on', inAnomaly);

    draw(inAnomaly);
    requestAnimationFrame(step);
  }

  function draw(anomaly){
    const w = cvs.clientWidth, h = cvs.clientHeight;
    ctx.clearRect(0,0,w,h);

    // grid
    ctx.strokeStyle = '#1A1D20';
    ctx.lineWidth = 1;
    ctx.beginPath();
    for (let x=0;x<=w;x+=Math.max(24,w/12)){ ctx.moveTo(x,0); ctx.lineTo(x,h); }
    for (let y=0;y<=h;y+=h/4){ ctx.moveTo(0,y); ctx.lineTo(w,y); }
    ctx.stroke();

    // zero line
    ctx.strokeStyle = '#2A3035';
    ctx.setLineDash([2,4]);
    ctx.beginPath(); ctx.moveTo(0, h/2); ctx.lineTo(w, h/2); ctx.stroke();
    ctx.setLineDash([]);

    // waveform
    ctx.strokeStyle = anomaly ? '#FF5C5C' : '#CA4A0E';
    ctx.lineWidth = 1.25;
    ctx.shadowColor = anomaly ? 'rgba(255,92,92,.5)' : 'rgba(202,74,14,.45)';
    ctx.shadowBlur = 8;
    ctx.beginPath();
    const pts = buf;
    for (let i=0;i<pts.length;i++){
      const x = (i/(pts.length-1)) * w;
      const y = h/2 - pts[i] * (h*0.38);
      if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.stroke();
    ctx.shadowBlur = 0;

    // trailing cursor
    const lastX = w, lastY = h/2 - pts[pts.length-1]*(h*0.38);
    ctx.fillStyle = anomaly ? '#FF5C5C' : '#CA4A0E';
    ctx.beginPath(); ctx.arc(lastX-2, lastY, 2.5, 0, Math.PI*2); ctx.fill();
  }
  step();

  // Pointer-reactive glow on monitor cards
  document.querySelectorAll('.mon').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
      card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
    });
  });
</script>
