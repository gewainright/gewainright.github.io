<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>osrep.ai — constant state machine monitoring</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0A0C0D;
    --bg-1:#0F1214;
    --bg-2:#14181B;
    --line:#1E2327;
    --line-2:#2A3035;
    --dim:#6B7280;
    --mid:#9AA1A9;
    --ink:#E8EAE6;
    --ink-2:#F6F7F4;
    --amber:#CA4A0E;
    --amber-dim:#6E2908;
    --cyan:#4CC9F0;
    --red:#FF5C5C;
    --green:#4ADE80;
    --mono:'JetBrains Mono', ui-monospace, Menlo, monospace;
    --display:'Space Grotesk', 'JetBrains Mono', sans-serif;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);font-family:var(--mono);font-size:14px;line-height:1.55;-webkit-font-smoothing:antialiased}
  body{
    background:
      radial-gradient(1200px 600px at 80% -10%, rgba(202,74,14,.06), transparent 60%),
      radial-gradient(900px 500px at 0% 20%, rgba(76,201,240,.04), transparent 60%),
      var(--bg);
    background-attachment: fixed;
  }
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--amber);color:#0A0C0D}

  /* Layout */
  .wrap{max-width:1280px;margin:0 auto;padding:0 32px}
  .rule{height:1px;background:var(--line);width:100%}
  .rule-dash{height:1px;background-image:linear-gradient(to right, var(--line-2) 50%, transparent 50%);background-size:8px 1px}

  /* Nav */
  .nav{position:sticky;top:0;z-index:50;backdrop-filter:blur(8px);background:rgba(10,12,13,.72);border-bottom:1px solid var(--line)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;height:56px}
  .brand{display:flex;align-items:center;gap:10px;font-weight:600;letter-spacing:-.01em}
  .brand .logo{width:22px;height:22px;position:relative}
  .brand-dot{width:6px;height:6px;border-radius:50%;background:var(--amber);box-shadow:0 0 12px rgba(202,74,14,.8);animation:pulse 1.6s ease-in-out infinite}
  @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.85)}}
  .brand-name{font-family:var(--mono);font-size:14px}
  .brand-name em{font-style:normal;color:var(--amber)}
  .nav-links{display:flex;gap:28px;font-size:12px;color:var(--mid)}
  .nav-links a:hover{color:var(--ink)}
  .nav-cta{font-size:12px;padding:8px 14px;border:1px solid var(--line-2);color:var(--ink);transition:all .15s ease}
  .nav-cta:hover{border-color:var(--amber);color:var(--amber)}
  .status-chip{display:inline-flex;align-items:center;gap:8px;font-size:11px;color:var(--mid);padding:4px 10px;border:1px solid var(--line);border-radius:999px}
  .status-chip .dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px rgba(74,222,128,.6)}

  /* ---------- HERO ---------- */
  .hero{position:relative;padding:72px 0 40px;overflow:hidden}
  .hero::before{
    content:"";position:absolute;inset:0;pointer-events:none;
    background-image:
      linear-gradient(to right, rgba(30,35,39,.35) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(30,35,39,.35) 1px, transparent 1px);
    background-size:48px 48px;
    mask-image:radial-gradient(ellipse at 50% 30%, #000 30%, transparent 75%);
  }
  .hero-inner{position:relative;z-index:2}
  .kicker{display:inline-flex;align-items:center;gap:10px;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--mid);margin-bottom:28px}
  .kicker::before{content:"";width:24px;height:1px;background:var(--amber)}
  .kicker em{font-style:normal;color:var(--amber);letter-spacing:.18em}
  h1.headline{
    font-family:var(--display);
    font-weight:500;
    font-size:clamp(40px, 6.2vw, 84px);
    line-height:1.02;
    letter-spacing:-.035em;
    margin:0 0 24px;
    max-width:16ch;
    color:var(--ink-2);
  }
  h1 .amber{color:var(--amber)}
  h1 .dim{color:var(--dim)}
  h1 .slash{color:var(--amber);font-weight:400}
  .sub{
    font-family:var(--mono);
    font-size:16px;line-height:1.65;color:var(--mid);max-width:62ch;margin:0 0 36px;
  }
  .sub strong{color:var(--ink);font-weight:500}
  .hero-cta{display:flex;gap:12px;align-items:center;flex-wrap:wrap}
  .btn{display:inline-flex;align-items:center;gap:10px;padding:12px 18px;font-family:var(--mono);font-size:13px;border:1px solid var(--line-2);color:var(--ink);transition:all .15s ease;cursor:pointer;background:transparent}
  .btn.primary{background:var(--amber);color:#0A0C0D;border-color:var(--amber);font-weight:600}
  .btn.primary:hover{background:#E35D1F;border-color:#E35D1F;box-shadow:0 0 0 4px rgba(202,74,14,.12)}
  .btn:hover{border-color:var(--ink);color:var(--ink-2)}
  .btn .arrow{transition:transform .15s ease}
  .btn:hover .arrow{transform:translateX(3px)}

  /* Waveform panel */
  .scope{
    margin-top:64px;
    border:1px solid var(--line);
    background:linear-gradient(180deg, rgba(20,24,27,.6), rgba(10,12,13,.6));
    position:relative;
  }
  .scope-head{display:flex;align-items:stretch;border-bottom:1px solid var(--line);font-size:11px;color:var(--mid)}
  .scope-head > div{padding:10px 16px;border-right:1px solid var(--line);display:flex;align-items:center;gap:8px}
  .scope-head > div:last-child{border-right:none;margin-left:auto}
  .scope-head .label{color:var(--dim);text-transform:uppercase;letter-spacing:.12em;font-size:10px}
  .scope-head .val{color:var(--ink)}
  .scope-head .val.amber{color:var(--amber)}
  .scope-head .val.cyan{color:var(--cyan)}
  .scope-head .val.red{color:var(--red)}
  .scope-body{display:grid;grid-template-columns:1fr 240px;min-height:260px}
  .scope-canvas{position:relative;border-right:1px solid var(--line)}
  .scope-canvas canvas{display:block;width:100%;height:100%}
  .scope-ticks{position:absolute;inset:0;pointer-events:none;display:flex;justify-content:space-between;padding:0 12px;font-size:9px;color:var(--dim);align-items:flex-end}
  .scope-ticks span{padding-bottom:6px}
  .scope-anomaly{position:absolute;top:12px;left:50%;transform:translateX(-50%);font-size:10px;color:var(--amber);letter-spacing:.12em;text-transform:uppercase;opacity:0;transition:opacity .3s}
  .scope-anomaly.on{opacity:1}
  .scope-side{padding:20px;display:flex;flex-direction:column;gap:10px;font-size:11px;justify-content:center}
  .illus-note .illus-title{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--amber);margin-bottom:10px}
  .illus-note p{font-size:12px;color:var(--mid);line-height:1.65;margin:0}
  .illus-note p em{font-style:italic;color:var(--ink)}

  /* Stat strip under hero */
  .stats{display:grid;grid-template-columns:repeat(4,1fr);margin-top:40px;border:1px solid var(--line);background:var(--bg-1)}
  .stat{padding:22px;border-right:1px solid var(--line)}
  .stat:last-child{border-right:none}
  .stat .k{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--dim);margin-bottom:10px}
  .stat .v{font-family:var(--display);font-size:28px;font-weight:500;color:var(--ink-2);letter-spacing:-.02em}
  .stat .v .unit{color:var(--dim);font-size:14px;margin-left:4px}

  /* Section header pattern */
  .section{padding:96px 0;position:relative}
  .sec-head{display:grid;grid-template-columns:160px 1fr;gap:32px;margin-bottom:56px;align-items:baseline}
  .sec-index{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--amber)}
  .sec-index span{color:var(--dim)}
  .sec-title{font-family:var(--display);font-size:clamp(28px,3.6vw,48px);font-weight:500;letter-spacing:-.025em;color:var(--ink-2);margin:0;max-width:22ch;line-height:1.1}
  .sec-lead{font-size:14px;color:var(--mid);max-width:60ch;margin-top:16px}

  /* Monitor grid */
  .mon-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:0;border:1px solid var(--line)}
  .mon{position:relative;padding:28px;border-right:1px solid var(--line);border-bottom:1px solid var(--line);min-height:220px;display:flex;flex-direction:column;justify-content:space-between;background:var(--bg-1);transition:background .15s}
  .mon:hover{background:var(--bg-2)}
  .mon.w-6{grid-column:span 6}
  .mon.w-4{grid-column:span 4}
  .mon.w-3{grid-column:span 3}
  .mon.w-12{grid-column:span 12}
  .mon:nth-child(3n){border-right:none}
  .mon-tag{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);display:flex;justify-content:space-between;align-items:center}
  .mon-tag .num{color:var(--amber)}
  .mon h3{font-family:var(--display);font-size:22px;font-weight:500;margin:14px 0 8px;letter-spacing:-.01em;color:var(--ink-2)}
  .mon p{font-size:13px;color:var(--mid);margin:0;line-height:1.6;max-width:42ch}
  .mon-foot{display:flex;gap:18px;margin-top:20px;font-size:10px;color:var(--dim);letter-spacing:.1em;text-transform:uppercase}
  .mon-foot span{display:flex;align-items:center;gap:6px}
  .mon-foot .d{width:4px;height:4px;border-radius:50%;background:var(--amber)}

  /* Diagram-style svg in mon */
  .mon-diagram{position:absolute;bottom:0;right:0;width:50%;height:60%;opacity:.18;pointer-events:none}

  /* Sensor types */
  .sensors{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid var(--line)}
  .sensor{padding:32px;border-right:1px solid var(--line);position:relative;min-height:320px;background:var(--bg-1);display:flex;flex-direction:column}
  .sensor:last-child{border-right:none}
  .sensor-glyph{height:120px;margin-bottom:22px;display:flex;align-items:center;justify-content:center;border:1px dashed var(--line-2);background:linear-gradient(180deg, rgba(202,74,14,.02), transparent)}
  .sensor-kicker{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--amber);margin-bottom:8px}
  .sensor h3{font-family:var(--display);font-size:24px;font-weight:500;letter-spacing:-.02em;margin:0 0 10px;color:var(--ink-2)}
  .sensor p{font-size:13px;color:var(--mid);margin:0 0 18px;line-height:1.6}
  .sensor-specs{margin-top:auto;display:grid;grid-template-columns:1fr 1fr;gap:10px;padding-top:18px;border-top:1px solid var(--line);font-size:11px}
  .sensor-specs .k{color:var(--dim);text-transform:uppercase;letter-spacing:.1em;font-size:10px;margin-bottom:2px}
  .sensor-specs .v{color:var(--ink)}

  /* How it works mini */
  .how-note{border-left:2px solid var(--amber);padding:20px 24px;background:var(--bg-1);margin-top:32px;font-size:14px;color:var(--mid);max-width:80ch}
  .how-note strong{color:var(--ink);font-weight:500}

  /* FAQ */
  .faq{border-top:1px solid var(--line)}
  .q{border-bottom:1px solid var(--line);padding:24px 0;cursor:pointer;display:grid;grid-template-columns:48px 1fr 48px;gap:20px;align-items:start;transition:background .15s}
  .q:hover{background:rgba(202,74,14,.02)}
  .q-num{font-size:11px;color:var(--dim);padding-top:4px;letter-spacing:.1em}
  .q-title{font-family:var(--display);font-size:20px;font-weight:500;color:var(--ink-2);letter-spacing:-.01em;margin:0}
  .q-toggle{font-family:var(--mono);color:var(--amber);font-size:18px;text-align:right;transition:transform .2s}
  .q.open .q-toggle{transform:rotate(45deg)}
  .q-body{grid-column:2 / 3;max-height:0;overflow:hidden;transition:max-height .3s ease, margin .3s ease, opacity .3s ease;opacity:0;color:var(--mid);font-size:13px;line-height:1.7;max-width:68ch}
  .q.open .q-body{max-height:400px;margin-top:14px;opacity:1}

  /* Form */
  .form-wrap{border:1px solid var(--line);background:linear-gradient(180deg, var(--bg-1), var(--bg));padding:48px;display:grid;grid-template-columns:340px 1fr;gap:64px}
  .form-intro h2{font-family:var(--display);font-size:36px;font-weight:500;letter-spacing:-.025em;margin:0 0 16px;color:var(--ink-2);line-height:1.1}
  .form-intro p{color:var(--mid);font-size:13px;line-height:1.65;margin:0 0 20px}
  .form-intro .contact{font-size:12px;color:var(--dim);border-top:1px dashed var(--line-2);padding-top:18px;margin-top:24px}
  .form-intro .contact a{color:var(--amber)}
  form{display:grid;grid-template-columns:1fr 1fr;gap:22px 24px}
  .field{display:flex;flex-direction:column;gap:6px}
  .field.full{grid-column:1 / -1}
  .field label{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);display:flex;justify-content:space-between}
  .field label .req{color:var(--amber)}
  .field input, .field select, .field textarea{
    font-family:var(--mono);
    font-size:13px;
    background:transparent;
    border:none;
    border-bottom:1px solid var(--line-2);
    color:var(--ink);
    padding:10px 0;
    outline:none;
    transition:border-color .15s;
    border-radius:0;
  }
  .field input:focus, .field select:focus, .field textarea:focus{border-bottom-color:var(--amber)}
  .field textarea{min-height:100px;resize:vertical;border:1px solid var(--line-2);padding:12px}
  .field textarea:focus{border-color:var(--amber)}
  .field select{appearance:none;-webkit-appearance:none;background-image:linear-gradient(45deg,transparent 50%, var(--mid) 50%),linear-gradient(135deg, var(--mid) 50%, transparent 50%);background-position:calc(100% - 14px) 18px, calc(100% - 9px) 18px;background-size:5px 5px;background-repeat:no-repeat;padding-right:28px}
  .field select option{background:var(--bg-1);color:var(--ink)}
  .form-foot{grid-column:1 / -1;display:flex;justify-content:space-between;align-items:center;margin-top:12px;padding-top:20px;border-top:1px dashed var(--line-2);gap:20px;flex-wrap:wrap}
  .form-foot .hint{font-size:11px;color:var(--dim)}
  .submit{display:inline-flex;align-items:center;gap:10px;padding:14px 24px;background:var(--amber);color:#0A0C0D;font-family:var(--mono);font-size:13px;font-weight:600;border:none;cursor:pointer;transition:all .15s}
  .submit:hover{background:#E35D1F;box-shadow:0 0 0 4px rgba(202,74,14,.15)}
  .submit:disabled{opacity:.5;cursor:not-allowed}
  .form-success{grid-column:1 / -1;padding:24px;border:1px solid var(--green);background:rgba(74,222,128,.04);color:var(--ink);font-size:13px;display:none}
  .form-success.show{display:block}

  /* Footer */
  footer{border-top:1px solid var(--line);padding:40px 0 32px;color:var(--dim);font-size:11px;letter-spacing:.08em}
  .foot-grid{display:grid;grid-template-columns:1fr auto auto auto;gap:32px;align-items:baseline}
  .foot-grid .loc{display:flex;gap:18px;color:var(--mid)}

  /* Responsive */
  @media (max-width: 900px){
    .wrap{padding:0 20px}
    .nav-links{display:none}
    .scope-body{grid-template-columns:1fr}
    .scope-canvas{border-right:none;border-bottom:1px solid var(--line)}
    .stats{grid-template-columns:1fr 1fr}
    .stat{border-right:none;border-bottom:1px solid var(--line)}
    .sec-head{grid-template-columns:1fr;gap:8px}
    .mon-grid{grid-template-columns:1fr}
    .mon{grid-column:span 12 !important;border-right:none !important}
    .sensors{grid-template-columns:1fr}
    .sensor{border-right:none;border-bottom:1px solid var(--line)}
    .form-wrap{grid-template-columns:1fr;padding:28px;gap:32px}
    form{grid-template-columns:1fr}
    .foot-grid{grid-template-columns:1fr;gap:12px}
  }

  /* Small tech details */
  .crosshair{position:absolute;width:12px;height:12px;border:1px solid var(--amber);opacity:.6}
  .crosshair.tl{top:-1px;left:-1px;border-right:none;border-bottom:none}
  .crosshair.tr{top:-1px;right:-1px;border-left:none;border-bottom:none}
  .crosshair.bl{bottom:-1px;left:-1px;border-right:none;border-top:none}
  .crosshair.br{bottom:-1px;right:-1px;border-left:none;border-top:none}

  .section-divider{display:flex;align-items:center;gap:16px;font-size:10px;color:var(--dim);letter-spacing:.2em;text-transform:uppercase;padding:0 0 8px}
  .section-divider::before, .section-divider::after{content:"";flex:1;height:1px;background:var(--line)}

  /* ========== LUXE LAYER ========== */

  /* Film grain over the whole page */
  body::after{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:100;opacity:.035;mix-blend-mode:overlay;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)' opacity='1'/></svg>");
  }

  /* Nav: subtle animated hairline underlining the bar */
  .nav{position:sticky;top:0;z-index:50}
  .nav::after{
    content:"";position:absolute;left:0;right:0;bottom:-1px;height:1px;
    background:linear-gradient(90deg, transparent, var(--amber) 20%, var(--amber) 80%, transparent);
    opacity:.4;
  }

  /* Kicker pulse */
  .kicker-pulse{
    width:8px;height:8px;border-radius:50%;background:var(--amber);
    box-shadow:0 0 0 0 rgba(202,74,14,.65);
    animation:pulseRing 2.4s ease-out infinite;
    display:inline-block;
  }
  @keyframes pulseRing{
    0%{box-shadow:0 0 0 0 rgba(202,74,14,.6)}
    70%{box-shadow:0 0 0 10px rgba(202,74,14,0)}
    100%{box-shadow:0 0 0 0 rgba(202,74,14,0)}
  }

  /* Headline: bigger, more editorial + shimmer on the accent word */
  h1.headline{
    font-size:clamp(46px, 7.8vw, 108px);
    letter-spacing:-.04em;
    font-weight:500;
  }
  .amber-fx{
    background: linear-gradient(110deg,
      var(--amber) 0%, var(--amber) 40%,
      #F27B3C 50%,
      var(--amber) 60%, var(--amber) 100%);
    background-size:200% 100%;
    -webkit-background-clip:text;background-clip:text;
    color:transparent;
    animation:shine 6s linear infinite;
    position:relative;
  }
  @keyframes shine{0%{background-position:200% 0}100%{background-position:-200% 0}}

  /* Hero: extra luxe backdrop — radial glow orbiting behind */
  .hero::after{
    content:"";position:absolute;pointer-events:none;z-index:1;
    width:640px;height:640px;border-radius:50%;
    background:radial-gradient(circle, rgba(202,74,14,.10), transparent 60%);
    top:-120px;right:-140px;
    filter:blur(20px);
    animation:drift 18s ease-in-out infinite alternate;
  }
  @keyframes drift{
    0%{transform:translate(0,0)}
    100%{transform:translate(-40px,20px)}
  }

  /* Sub copy: richer */
  .sub{font-size:17px;line-height:1.7;max-width:58ch}
  .sub strong{color:var(--amber);font-weight:500}

  /* Button: inner glow on primary + chevron */
  .btn{transition:all .25s cubic-bezier(.2,.8,.2,1);border-radius:2px}
  .btn.primary{
    box-shadow: inset 0 1px 0 rgba(255,255,255,.15), 0 0 0 0 rgba(202,74,14,.35);
    padding:14px 22px;font-size:13px;
  }
  .btn.primary:hover{
    transform:translateY(-1px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.25), 0 10px 30px -8px rgba(202,74,14,.55), 0 0 0 4px rgba(202,74,14,.12);
  }
  .btn:not(.primary){padding:14px 22px}

  /* Scope: richer frame — corner ticks, scan line, glowing ruler */
  .scope{
    background:
      radial-gradient(ellipse at 70% 10%, rgba(202,74,14,.06), transparent 50%),
      linear-gradient(180deg, rgba(20,24,27,.85), rgba(10,12,13,.85));
    box-shadow:
      inset 0 0 0 1px rgba(202,74,14,.08),
      0 30px 60px -30px rgba(0,0,0,.9);
  }
  .scope::before{
    content:"";position:absolute;left:0;right:0;top:0;height:2px;pointer-events:none;
    background:linear-gradient(90deg, transparent, var(--amber), transparent);
    opacity:.55;
    animation:scan 5s linear infinite;
  }
  @keyframes scan{
    0%{transform:translateY(0);opacity:0}
    20%{opacity:.55}
    80%{opacity:.55}
    100%{transform:translateY(260px);opacity:0}
  }
  .crosshair{width:14px;height:14px;border-width:1.5px}

  /* Section titles: editorial scale-up */
  .sec-title{font-size:clamp(32px,4.2vw,56px);letter-spacing:-.03em}
  .sec-lead{font-size:15px}

  /* Monitor cards: lift + accent glow on hover */
  .mon{transition:all .3s cubic-bezier(.2,.8,.2,1);overflow:hidden}
  .mon::before{
    content:"";position:absolute;inset:0;pointer-events:none;opacity:0;transition:opacity .3s;
    background:radial-gradient(400px 200px at var(--mx,50%) var(--my,30%), rgba(202,74,14,.10), transparent 60%);
  }
  .mon:hover::before{opacity:1}
  .mon:hover h3{color:var(--amber)}
  .mon h3{transition:color .2s}

  /* Sensor cards: refine */
  .sensor{transition:background .3s}
  .sensor:hover{background:var(--bg-2)}
  .sensor-glyph{background:
    radial-gradient(ellipse at 50% 50%, rgba(202,74,14,.04), transparent 70%),
    linear-gradient(180deg, rgba(202,74,14,.02), transparent);
  }

  /* Form: richer chrome */
